# Leetcode 1070: Product sales analysis III
# Difficulty : Medium
# Database : Mysql

SELECT
s.product_id,
s.year AS first_year,
s.quantity,
s.price
FROM Sales s
JOIN (
    SELECT 
        product_id,
        MIN(year) AS first_year
     FROM Sales
     GROUP BY product_id   
) f
ON s.product_id = f.product_id
AND s.year = f.first_year;
